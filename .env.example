# MLflow tracking configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=customer-intel-experiments
MLFLOW_ARTIFACT_ROOT=./mlruns

# Model selection / serving
MODEL_RUN_ID=
# Example: MODEL_RUN_ID=1234567890abcdef1234567890abcdef

# RAG / FAISS configuration
FAISS_INDEX_PATH=./data/faiss.index
SIMILARITY_THRESHOLD=0.35

# LLM configuration (no real keys here)
LLM_MODEL_NAME=local-mistral
LLM_API_KEY=

# Logging configuration
LOG_LEVEL=INFO

# Application ports
APP_PORT=8000
RAG_APP_PORT=8001
